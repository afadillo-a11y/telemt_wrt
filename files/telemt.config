# Default UCI Configuration for Telemt MTProxy (Headless Core)
# This file provides the fallback values ensuring the LuCI WebUI renders correctly.
config telemt 'general'
	option enabled '0'
	option port '8443'
	option api_port '9091'
	option metrics_port '9092'
	option api_enabled '1'
	option minimal_runtime_enabled '1'
	option metrics_allow_lo '1'
	option metrics_allow_lan '1'
	option metrics_whitelist ''
	option mode 'tls'
	option log_level 'normal'
	option domain 'google.com'
	option auto_fw '1'
	option listen_ipv4 '1'
	option listen_ipv6 '0'
	option prefer_ip '4'
	option use_middle_proxy '0'
	option use_stun '0'
	
	# Anti-censorship & TLS tuning defaults
	option mask_proxy_protocol '0'
	option fake_cert_len '2048'
	option tls_full_cert_ttl_secs '0'
	option replay_window_secs '1800'
	option ignore_time_skew '0'
	option desync_all_full '0'

	# Middle-End adaptive tuning defaults (Hidden under UI spoiler)
	option me_pool_size '16'
	option me_warm_standby '8'
	option hardswap '1'
	option me_drain_ttl '90'
	option auto_degradation '1'
	option degradation_min_dc '2'
	
	# Custom user scripts/bot update interval
	option update_every '300'
